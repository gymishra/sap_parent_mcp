{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SSMAccess",
      "Effect": "Allow",
      "Action": ["ssm:GetParameter", "ssm:PutParameter"],
      "Resource": "arn:aws:ssm:us-east-1:953841955037:parameter/sap_*"
    },
    {
      "Sid": "BedrockInvoke",
      "Effect": "Allow",
      "Action": ["bedrock:InvokeModel"],
      "Resource": "*"
    },
    {
      "Sid": "S3Staging",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:CreateBucket", "s3:PutBucketVersioning", "s3:ListBucket"],
      "Resource": ["arn:aws:s3:::sap-mcp-generator-*", "arn:aws:s3:::sap-mcp-generator-*/*"]
    },
    {
      "Sid": "CodeBuildTrigger",
      "Effect": "Allow",
      "Action": ["codebuild:StartBuild", "codebuild:BatchGetBuilds", "codebuild:CreateProject"],
      "Resource": "*"
    },
    {
      "Sid": "IAMForCodeBuild",
      "Effect": "Allow",
      "Action": ["iam:CreateRole", "iam:PutRolePolicy", "iam:GetRole", "iam:PassRole"],
      "Resource": "arn:aws:iam::953841955037:role/sap-mcp-generator-*"
    }
  ]
}
